      "format": "{1} / {2} ({3})",
      "key": "َ°¾´ ",
      "keyColor": "34"
    },
    {
      "type": "disk",
      "format": "{1} / {2} ({3}) ({9})",
      "key": "ï†؟ ",
      "keyColor": "34"
    },
    {
      "type": "battery",
      "key": "َ°پ¹ ",
      "keyColor": "34"
    },
    "break",
    // --- NETWORK ---
    {
      "type": "localip",
      "key": "َ°©ں ",
      "keyColor": "34"
    },
    {
      "type": "publicip",
      "key": "َ°©  ",
      "keyColor": "34"
    },
    "break",
    {
      "type": "custom",
      "format": "\u001b[90mï†’  \u001b[31mï†’  \u001b[32mï†’  \u001b[33mï†’  \u001b[34mï†’  \u001b[35mï†’  \u001b[36mï†’  \u001b[37mï†’"
    },
    "break"
  ]
}
