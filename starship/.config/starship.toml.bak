# A cleaner, two-line layout with a focus on the journey
format = """
[╭─](fg:ship_wood)$os $username[in ](fg:subtle)$directory $git_branch$git_status$fill $nodejs$python$custom[at ](fg:subtle)$time
[╰─](fg:ship_wood)$character """

scan_timeout = 500
add_newline = true
palette = "sunny"

[palettes.sunny]
ship_wood = "#A67B5B"     # Warm cedar/mast color
sunny_yellow = "#FFD700"  # The mane/sunlight
ocean_blue = "#0077BE"   # Grand Line waters
grass_green = "#78AB46"   # The deck grass
danger_red = "#ED1C24"    # Flag/Iron Pirate accents
subtle = "#666666"        # For "in" and "at" connectors

[os]
disabled = false
format = "[$symbol]($style)"
style = "bold ocean_blue"

[os.symbols]
Arch = "󰣇 "
EndeavourOS = " "
Linux = "󰌽 "

[username]
show_always = true
style_user = "bold sunny_yellow"
style_root = "bold danger_red"
format = "[$user]($style) "

[directory]
style = "bold ocean_blue"
format = "[$path]($style) "
truncation_length = 3
truncation_symbol = "…/"

[git_branch]
symbol = " "
style = "bold grass_green"
format = "on [$symbol$branch]($style) "

[git_status]
style = "bold grass_green"
format = "([$all_status$ahead_behind]($style) )"

[character]
# Using a lion-like or sun-like symbol for the figurehead
success_symbol = "[🦁](fg:sunny_yellow)" 
error_symbol = "[💀](fg:danger_red)"

[nodejs]
symbol = " "
style = "bold sunny_yellow"
format = "via [$symbol($version)]($style) "

[python]
symbol = " "
style = "bold sunny_yellow"
format = "via [$symbol($version)]($style) "

[time]
disabled = false
time_format = "%R"
style = "bold subtle"
format = "[$time]($style)"

[fill]
symbol = " "

# Keeping these simple and integrated
[status]
disabled = false
format = "[$symbol]($style)"

[cmd_duration]
min_time = 2000
style = "italic subtle"
format = "took [$duration]($style)"
